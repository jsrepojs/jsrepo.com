{
	"name": "jsrepo.com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.11.1",
	"scripts": {
		"dev": "dotenvx run --env-file .env.development.local -- vite dev",
		"stage": "dotenvx run --env-file .env.local -- vite dev",
		"build": "vite build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"migrations:generate:dev": "dotenvx run --env-file .env.development.local -- drizzle-kit generate",
		"migrations:migrate:dev": "dotenvx run --env-file .env.development.local -- drizzle-kit migrate",
		"migrations:generate:prod": "dotenvx run --env-file .env.local -- drizzle-kit generate",
		"migrations:migrate:prod": "dotenvx run --env-file .env.local -- drizzle-kit migrate"
	},
